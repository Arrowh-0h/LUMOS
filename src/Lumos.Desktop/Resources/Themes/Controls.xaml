<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ==================================================
         TEXT STYLES
         ================================================== -->
    <Style TargetType="TextBlock" x:Key="BodyText">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="SecondaryText" BasedOn="{StaticResource BodyText}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="DisplayHeading">
        <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize4xl}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="SectionHeading">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeXl}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="MonoLabel" BasedOn="{StaticResource SecondaryText}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
        <Setter Property="Opacity" Value="0.75"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="DangerText" BasedOn="{StaticResource BodyText}">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
    </Style>

    <!-- ==================================================
         PRIMARY BUTTON - sharper, with edge glow
         ================================================== -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- v2: flat, sharp, no glow halo. -->
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         SECONDARY BUTTON - bordered, cyan-on-hover
         ================================================== -->
    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         WINDOW CHROME BUTTONS
         ================================================== -->
    <Style TargetType="Button" x:Key="WindowChromeButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="WindowChromeCloseButton" BasedOn="{StaticResource WindowChromeButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================================================
         TEXTBOX - terminal-style with cyan caret
         ================================================== -->
    <Style TargetType="TextBox" x:Key="LumosTextBox">
        <Setter Property="Background" Value="#FF050810"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentCyanBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentCyanDimBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <!-- Bottom focus accent line -->
                        <Rectangle x:Name="FocusLine"
                                   Height="2"
                                   VerticalAlignment="Bottom"
                                   Fill="{StaticResource AccentCyanBrush}"
                                   Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                            <Setter TargetName="FocusLine" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         PASSWORDBOX - same terminal treatment
         ================================================== -->
    <Style TargetType="PasswordBox" x:Key="LumosPasswordBox">
        <Setter Property="Background" Value="#FF050810"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentCyanBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentCyanDimBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="PasswordChar" Value="●"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <Rectangle x:Name="FocusLine"
                                   Height="2"
                                   VerticalAlignment="Bottom"
                                   Fill="{StaticResource AccentCyanBrush}"
                                   Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                            <Setter TargetName="FocusLine" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         WINDOW DEFAULTS
         ================================================== -->
    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}"/>

    <!-- ==================================================
         NEON CARD - a ContentControl style. Use as:
             <ContentControl Style="{StaticResource NeonCard}">
                 ...your content here...
             </ContentControl>
         The content stays in the parent's name scope (unlike a UserControl
         with a CardContent dependency property), so x:Name on children
         resolves to fields in the parent code-behind.
         ================================================== -->
    <Style TargetType="ContentControl" x:Key="NeonCard">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <!-- v2: flat card. No glow halo, no glowing tron line.
                         A 1px grey border + a thin steel-blue top accent line. -->
                    <Border Background="{StaticResource CardGradientBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Thin flat top accent (steel-blue hairline, no glow) -->
                            <Rectangle Grid.Row="0" Height="2" Fill="{StaticResource ScanlineBrush}"/>

                            <Grid Grid.Row="1">
                                <!-- Subtle grey corner brackets (no neon, low opacity) -->
                                <Path Stroke="{StaticResource BorderBrush}"
                                      StrokeThickness="1"
                                      Data="M 0,8 L 0,0 L 8,0"
                                      HorizontalAlignment="Left" VerticalAlignment="Top"
                                      Margin="8,8,0,0"/>
                                <Path Stroke="{StaticResource BorderBrush}"
                                      StrokeThickness="1"
                                      Data="M 0,0 L 8,0 L 8,8"
                                      HorizontalAlignment="Right" VerticalAlignment="Top"
                                      Margin="0,8,8,0"/>
                                <Path Stroke="{StaticResource BorderBrush}"
                                      StrokeThickness="1"
                                      Data="M 0,0 L 0,8 L 8,8"
                                      HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                      Margin="8,0,0,8"/>
                                <Path Stroke="{StaticResource BorderBrush}"
                                      StrokeThickness="1"
                                      Data="M 0,8 L 8,8 L 8,0"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                      Margin="0,0,8,8"/>

                                <!-- Actual user content -->
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         ENTRY LIST ITEM
         A ListBoxItem style with cyber selection treatment.
         ================================================== -->
    <Style TargetType="ListBoxItem" x:Key="EntryListItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <!-- Left accent bar - hidden by default, gold on selection -->
                        <Rectangle x:Name="AccentBar"
                                   Width="2"
                                   HorizontalAlignment="Left"
                                   Fill="{StaticResource AccentGoldBrush}"
                                   Opacity="0"/>
                        <!-- Row body -->
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <!-- Bottom divider line -->
                        <Rectangle Height="1"
                                   VerticalAlignment="Bottom"
                                   Fill="{StaticResource BorderBrush}"
                                   Opacity="0.5"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#22162033"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33F5C842"/>
                            <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         GHOST BUTTON - text-only with hover underline (used for inline actions)
         ================================================== -->
    <Style TargetType="Button" x:Key="GhostButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentCyanDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                            <Setter TargetName="Bd" Property="Background" Value="#221B7A7A"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger-tinted ghost button for delete -->
    <Style TargetType="Button" x:Key="DangerGhostButton" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderBrush" Value="#552A1116"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================================================
         FAB - the "+" add button (now a sharp square)
         ================================================== -->
    <Style TargetType="Button" x:Key="FabButton">
        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- v2: flat sharp square, no glow halo, no rounding. -->
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueDimBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================
         THEMED SCROLLBAR - thin, dark, cyan-on-hover
         ================================================== -->
    <Style TargetType="ScrollBar" x:Key="LumosScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="Bd"
                                                    Background="{StaticResource BorderBrush}"
                                                    CornerRadius="0"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentCyanDimBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ==================================================
         TOOLTIP - global implicit style so every tooltip in
         the app is readable. The default Windows tooltip is a
         near-white box with pale text (invisible on our theme).
         Dark surface, light text, sharp 1px steel border.
         ================================================== -->
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource AccentBlueBrush}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
