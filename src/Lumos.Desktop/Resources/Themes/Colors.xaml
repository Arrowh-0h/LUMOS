<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ==================================================
         COLORS — v2 "black-dominant, sharp, low-glow"
         Palette: black (dominant) + neutral grey (structure)
         + steel-blue (primary accent) + red (danger) + gold
         (brand wordmark & TOTP ring ONLY).

         NOTE on key names: we keep the old brush KEY names so
         existing views don't break. The cyan keys now resolve
         to steel-blue, so every old "AccentCyan*" reference
         becomes blue automatically. We'll retire the cyan names
         gradually during the per-view alignment pass.
         ================================================== -->

    <!-- Backgrounds: near-pure black -> charcoal -> neutral dark grey -->
    <Color x:Key="BgDeepColor">#FF0A0A0B</Color>      <!-- window base, near-pure black -->
    <Color x:Key="BgBaseColor">#FF101012</Color>      <!-- panels -->
    <Color x:Key="SurfaceColor">#FF16161A</Color>     <!-- card body, neutral dark grey -->
    <Color x:Key="SurfaceHoverColor">#FF1E1E24</Color>
    <Color x:Key="BorderColor">#FF2A2A30</Color>      <!-- neutral grey border -->
    <Color x:Key="BorderFocusColor">#FF4A7DBF</Color> <!-- focus = steel-blue -->

    <!-- Gold — RESERVED for the LUMOS wordmark and the TOTP countdown ring.
         Deeper, less-neon than v1. Do not use for general buttons. -->
    <Color x:Key="AccentGoldColor">#FFE8B530</Color>
    <Color x:Key="AccentGoldHoverColor">#FFF5C84A</Color>
    <Color x:Key="AccentGoldDimColor">#FF6E5414</Color>
    <Color x:Key="AccentGoldShadowColor">#FFE8B530</Color>

    <!-- Steel-blue (cooler slate) — the PRIMARY accent. Buttons, focus,
         active sidebar, glyphs, links, info. These keys are named "Cyan"
         for backward-compat but are blue now. -->
    <Color x:Key="AccentCyanColor">#FF4A7DBF</Color>       <!-- primary steel-blue -->
    <Color x:Key="AccentCyanDimColor">#FF2C4A73</Color>    <!-- dim steel-blue -->
    <Color x:Key="AccentBlueColor">#FF4A7DBF</Color>       <!-- explicit alias -->
    <Color x:Key="AccentBlueHoverColor">#FF5B93D6</Color>  <!-- brighter on hover -->
    <Color x:Key="AccentBlueDimColor">#FF2C4A73</Color>

    <Color x:Key="SuccessColor">#FF3FB668</Color>
    <Color x:Key="DangerColor">#FFD63A4A</Color>          <!-- blood red, less neon than v1 -->
    <Color x:Key="DangerHoverColor">#FFE4566A</Color>
    <Color x:Key="WarningColor">#FFD99A2B</Color>

    <Color x:Key="TextPrimaryColor">#FFECECF0</Color>     <!-- near-white -->
    <Color x:Key="TextSecondaryColor">#FF9A9AA6</Color>   <!-- neutral grey -->
    <Color x:Key="TextDisabledColor">#FF55555F</Color>

    <!-- ==================================================
         SOLID BRUSHES
         ================================================== -->
    <SolidColorBrush x:Key="BgDeepBrush"        Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgBaseBrush"        Color="{StaticResource BgBaseColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"       Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush"  Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush"   Color="{StaticResource BorderFocusColor}"/>

    <SolidColorBrush x:Key="AccentGoldBrush"        Color="{StaticResource AccentGoldColor}"/>
    <SolidColorBrush x:Key="AccentGoldHoverBrush"   Color="{StaticResource AccentGoldHoverColor}"/>
    <SolidColorBrush x:Key="AccentGoldDimBrush"     Color="{StaticResource AccentGoldDimColor}"/>
    <SolidColorBrush x:Key="AccentGoldShadowBrush"  Color="{StaticResource AccentGoldShadowColor}"/>

    <!-- Steel-blue brushes (old "Cyan" names kept for compat) -->
    <SolidColorBrush x:Key="AccentCyanBrush"     Color="{StaticResource AccentCyanColor}"/>
    <SolidColorBrush x:Key="AccentCyanDimBrush"  Color="{StaticResource AccentCyanDimColor}"/>
    <!-- Preferred new names going forward -->
    <SolidColorBrush x:Key="AccentBlueBrush"      Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource AccentBlueHoverColor}"/>
    <SolidColorBrush x:Key="AccentBlueDimBrush"   Color="{StaticResource AccentBlueDimColor}"/>

    <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="WarningBrush"     Color="{StaticResource WarningColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"  Color="{StaticResource TextDisabledColor}"/>

    <!-- ==================================================
         BACKGROUND ATMOSPHERE (v2: flat + faint static grid)
         All neon corner-glows and CRT scanlines removed.
         These gradient keys are kept (some views reference them)
         but flattened so nothing glows.
         ================================================== -->

    <!-- Card fill: flat neutral dark grey (no gradient sheen). -->
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF16161A" Offset="0"/>
        <GradientStop Color="#FF131316" Offset="1"/>
    </LinearGradientBrush>

    <!-- Former gold corner glow -> fully transparent (kept so refs don't break). -->
    <SolidColorBrush x:Key="GoldCornerBrush" Color="#00000000"/>
    <SolidColorBrush x:Key="CyanCornerBrush" Color="#00000000"/>

    <!-- Former animated top-edge glow on cards -> a flat 1px grey hairline. -->
    <LinearGradientBrush x:Key="CardTopEdgeGlowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF2A2A30" Offset="0"/>
        <GradientStop Color="#002A2A30" Offset="1"/>
    </LinearGradientBrush>

    <!-- Former bright tron scanline -> a flat steel-blue hairline (no glow). -->
    <LinearGradientBrush x:Key="ScanlineBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#004A7DBF" Offset="0"/>
        <GradientStop Color="#444A7DBF" Offset="0.5"/>
        <GradientStop Color="#004A7DBF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Faint static grid — neutral grey, ~2% opacity. No animation. -->
    <DrawingBrush x:Key="GridPatternBrush"
                  TileMode="Tile"
                  Viewport="0,0,44,44"
                  ViewportUnits="Absolute"
                  Opacity="0.025">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#FF9A9AA6" Thickness="0.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="44,0"/>
                            <LineGeometry StartPoint="0,0" EndPoint="0,44"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- CRT scanlines removed: fully transparent (kept so refs don't break). -->
    <SolidColorBrush x:Key="ScanlinesBrush" Color="#00000000"/>

    <!-- ==================================================
         TYPOGRAPHY (unchanged)
         ================================================== -->
    <FontFamily x:Key="DisplayFontFamily">Cinzel, Cambria, Georgia, serif</FontFamily>
    <FontFamily x:Key="BodyFontFamily">Inter, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Cascadia Mono, Consolas, monospace</FontFamily>

    <sys:Double x:Key="FontSizeXs">11</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeMd">14</sys:Double>
    <sys:Double x:Key="FontSizeLg">16</sys:Double>
    <sys:Double x:Key="FontSizeXl">20</sys:Double>
    <sys:Double x:Key="FontSize2xl">28</sys:Double>
    <sys:Double x:Key="FontSize3xl">40</sys:Double>
    <sys:Double x:Key="FontSize4xl">64</sys:Double>

</ResourceDictionary>
