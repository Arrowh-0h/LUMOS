<UserControl x:Class="Lumos.Desktop.Views.ActivationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Lumos.Desktop.Views"
             xmlns:conv="clr-namespace:Lumos.Desktop.Converters">
    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <views:CyberBackdrop/>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="460">

            <!-- Brand mark -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock Text="LUMOS"
                           Style="{StaticResource DisplayHeading}"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource AccentGoldShadowColor}"
                                          BlurRadius="18"
                                          ShadowDepth="0"
                                          Opacity="0.45"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <TextBlock Text="// activation required"
                       Style="{StaticResource MonoLabel}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Activation card -->
            <ContentControl Style="{StaticResource NeonCard}">
                <StackPanel Margin="32,28">
                    <TextBlock Text="// LICENSE"
                               Style="{StaticResource MonoLabel}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Enter your product key"
                               Style="{StaticResource SectionHeading}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Lumos is free. A product key keeps activations tidy. Enter the key you were sent to continue."
                               Style="{StaticResource SecondaryText}"
                               Margin="0,0,0,20"/>

                    <TextBox x:Name="KeyField"
                             Style="{StaticResource LumosTextBox}"
                             Text="{Binding KeyInput, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFontFamily}"
                             FontSize="16"
                             Margin="0,0,0,8"
                             KeyDown="KeyField_KeyDown"/>

                    <TextBlock Text="Format: LUMOS-XXXX-XXXX-XXXX"
                               Style="{StaticResource MonoLabel}"
                               FontSize="10"
                               Margin="2,0,0,16"/>

                    <Button Content="ACTIVATE"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ActivateCommand}"/>

                    <TextBlock Style="{StaticResource DangerText}"
                               Margin="0,16,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                    <TextBlock Style="{StaticResource SecondaryText}"
                               FontSize="11"
                               Margin="0,16,0,0"
                               Text="{Binding SupportHint}"/>
                </StackPanel>
            </ContentControl>
        </StackPanel>
    </Grid>
</UserControl>
