<UserControl x:Class="Lumos.Desktop.Views.GeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:views="clr-namespace:Lumos.Desktop.Views"
             xmlns:conv="clr-namespace:Lumos.Desktop.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <views:CyberBackdrop/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Width="600" Margin="0,40,0,40">

                <!-- Header -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="// GENERATOR" Style="{StaticResource MonoLabel}"/>
                    <TextBlock Text="Generate a password" Style="{StaticResource SectionHeading}"
                               FontSize="24"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Mode tabs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="PASSPHRASE"
                            Style="{StaticResource GhostButton}"
                            Padding="20,10"
                            Margin="0,0,8,0"
                            Command="{Binding SwitchToPassphraseCommand}">
                        <Button.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPassphraseMode}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="RANDOM"
                            Style="{StaticResource GhostButton}"
                            Padding="20,10"
                            Command="{Binding SwitchToRandomCommand}">
                        <Button.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRandomMode}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Result card -->
                <ContentControl Style="{StaticResource NeonCard}" Margin="0,0,0,24">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="// OUTPUT" Style="{StaticResource MonoLabel}" Margin="0,0,0,8"/>
                        <Border Background="#FF050810"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="14,14"
                                MinHeight="56">
                            <TextBlock Text="{Binding Result}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource AccentCyanBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="11"
                                       Opacity="0.85"/>

                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Content="REGENERATE"
                                    Margin="0,0,8,0"
                                    Command="{Binding RegenerateCommand}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="COPY"
                                    Padding="20,8"
                                    MinHeight="36"
                                    Command="{Binding CopyCommand}"/>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <!-- ======== PASSPHRASE OPTIONS ======== -->
                <ContentControl Style="{StaticResource NeonCard}"
                                Visibility="{Binding IsPassphraseMode, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="// OPTIONS" Style="{StaticResource MonoLabel}" Margin="0,0,0,12"/>

                        <!-- Word count -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Words" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding WordCount}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="30"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="3" Maximum="10"
                                Value="{Binding WordCount, Mode=TwoWay}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,16"
                                Foreground="{StaticResource AccentBlueBrush}"/>

                        <!-- Separator -->
                        <TextBlock Text="Separator" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton Content="-" GroupName="Sep"
                                         IsChecked="{Binding Separator, Converter={StaticResource StringEqualityConverter}, ConverterParameter=-}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="." GroupName="Sep"
                                         IsChecked="{Binding Separator, Converter={StaticResource StringEqualityConverter}, ConverterParameter=.}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="_" GroupName="Sep"
                                         IsChecked="{Binding Separator, Converter={StaticResource StringEqualityConverter}, ConverterParameter=_}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="space" GroupName="Sep"
                                         IsChecked="{Binding IsSeparatorSpace}"
                                         Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <CheckBox Content="Capitalize words"
                                  IsChecked="{Binding CapitalizeWords}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="Append digits"
                                  IsChecked="{Binding AppendDigits}"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </ContentControl>

                <!-- ======== RANDOM OPTIONS ======== -->
                <ContentControl Style="{StaticResource NeonCard}"
                                Visibility="{Binding IsRandomMode, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="// OPTIONS" Style="{StaticResource MonoLabel}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Length" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RandomLength}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       MinWidth="30"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="8" Maximum="64"
                                Value="{Binding RandomLength, Mode=TwoWay}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,16"
                                Foreground="{StaticResource AccentBlueBrush}"/>

                        <CheckBox Content="Uppercase (A-Z)" IsChecked="{Binding IncludeUppercase}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Lowercase (a-z)" IsChecked="{Binding IncludeLowercase}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Digits (0-9)" IsChecked="{Binding IncludeDigits}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Symbols (!@#$...)" IsChecked="{Binding IncludeSymbols}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,12"/>
                        <CheckBox Content="Exclude ambiguous characters (0 O 1 l I |)"
                                  IsChecked="{Binding ExcludeAmbiguous}"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </ContentControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
