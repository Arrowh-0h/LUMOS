<UserControl x:Class="Lumos.Desktop.Views.UnlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Lumos.Desktop.Views"
             xmlns:conv="clr-namespace:Lumos.Desktop.Converters">
    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <!-- Atmosphere layer -->
        <views:CyberBackdrop/>

        <!-- Centered content stack -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="460">

            <!-- Brand mark with a soft, refined gold glow -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock Text="LUMOS"
                           Style="{StaticResource DisplayHeading}"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource AccentGoldShadowColor}"
                                          BlurRadius="18"
                                          ShadowDepth="0"
                                          Opacity="0.45"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <TextBlock Text="// a spell to reveal what you have hidden"
                       Style="{StaticResource MonoLabel}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Unlock card -->
            <ContentControl Style="{StaticResource NeonCard}">
                <StackPanel Margin="32,28">
                    <TextBlock Text="// AUTH"
                               Style="{StaticResource MonoLabel}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Enter your master password"
                               Style="{StaticResource SectionHeading}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="The vault unlocks only with your master password. Lumos cannot recover it for you."
                               Style="{StaticResource SecondaryText}"
                               Margin="0,0,0,20"/>

                    <PasswordBox x:Name="PasswordField"
                                 Style="{StaticResource LumosPasswordBox}"
                                 Margin="0,0,0,16"
                                 KeyDown="PasswordField_KeyDown"/>

                    <Button Content="UNLOCK"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Click="UnlockButton_Click"/>

                    <TextBlock Style="{StaticResource DangerText}"
                               Margin="0,16,0,0"
                               Text="{Binding ErrorMessage}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                    <TextBlock Style="{StaticResource DangerText}"
                               Margin="0,4,0,0"
                               Text="{Binding BackoffMessage}"
                               Visibility="{Binding BackoffMessage, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </ContentControl>
        </StackPanel>
    </Grid>
</UserControl>
