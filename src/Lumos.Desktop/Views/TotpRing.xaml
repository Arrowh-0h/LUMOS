<UserControl x:Class="Lumos.Desktop.Views.TotpRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="84" Height="84">
    <Grid>
        <!-- Background ring (full circle, dim) -->
        <Ellipse Stroke="{StaticResource BorderBrush}"
                 StrokeThickness="3"
                 Margin="6"
                 Opacity="0.5"/>

        <!-- Foreground arc, drawn by code-behind based on Fraction. -->
        <Path x:Name="ArcPath"
              Stroke="{StaticResource AccentGoldBrush}"
              StrokeThickness="3"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Margin="6">
            <Path.Effect>
                <DropShadowEffect Color="{StaticResource AccentGoldShadowColor}"
                                  BlurRadius="6"
                                  ShadowDepth="0"
                                  Opacity="0.35"/>
            </Path.Effect>
        </Path>

        <!-- Centered seconds-remaining numeric -->
        <TextBlock x:Name="SecondsLabel"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="20"
                   Foreground="{StaticResource AccentGoldBrush}">
            <TextBlock.Effect>
                <DropShadowEffect Color="{StaticResource AccentGoldShadowColor}"
                                  BlurRadius="5"
                                  ShadowDepth="0"
                                  Opacity="0.3"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</UserControl>
