<UserControl x:Class="Lumos.Desktop.Views.VaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Lumos.Desktop.Views"
             xmlns:conv="clr-namespace:Lumos.Desktop.Converters">
    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:BytesToImageConverter x:Key="BytesToImage"/>
    </UserControl.Resources>

    <Grid>
        <!-- Atmosphere layer -->
        <views:CyberBackdrop/>

        <!-- Two-column main area -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============ LEFT: ENTRY LIST ============ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section header -->
                <StackPanel Grid.Row="0" Margin="20,24,20,12">
                    <TextBlock Text="// ENTRIES" Style="{StaticResource MonoLabel}"/>
                    <TextBlock Text="Your vault" Style="{StaticResource SectionHeading}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Search box -->
                <TextBox Grid.Row="1"
                         Margin="20,0,20,12"
                         Style="{StaticResource LumosTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="SEARCH"
                         FontFamily="{StaticResource BodyFontFamily}"/>

                <!-- Scrollable entry list -->
                <Grid Grid.Row="2">
                    <ListBox x:Name="EntryList"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource EntryListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="20,0,20,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TypeGlyph}"
                                               Foreground="{StaticResource AccentCyanBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="{StaticResource BodyFontFamily}"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty list state -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="// EMPTY"
                                   Style="{StaticResource MonoLabel}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No entries yet"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding HasNoSearchResults, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="// NO MATCH"
                                   Style="{StaticResource MonoLabel}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Nothing matches that search"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- FAB - bottom right of list area -->
                    <Button Style="{StaticResource FabButton}"
                            Content="+"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,24,24"
                            Command="{Binding OpenAddOverlayCommand}"
                            ToolTip="Add entry"/>
                </Grid>
            </Grid>

            <!-- Vertical divider line between columns -->
            <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}" Opacity="0.5"/>

            <!-- ============ RIGHT: DETAIL ============ -->
            <Grid Grid.Column="2" DataContext="{Binding Detail}">
                <!-- Empty state (no selection) -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasEntry, Converter={StaticResource InvertBoolToVisibility}}">
                    <TextBlock Text="// IDLE"
                               Style="{StaticResource MonoLabel}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an entry"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Detail content (entry selected) -->
                <Grid Visibility="{Binding HasEntry, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="36,24,36,16">
                        <TextBlock Text="// DETAIL" Style="{StaticResource MonoLabel}"/>
                        <!-- Title (view mode) -->
                        <TextBlock Text="{Binding Entry.Title}"
                                   Style="{StaticResource SectionHeading}"
                                   FontSize="22"
                                   Margin="0,2,0,0"
                                   Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolToVisibility}}"/>
                        <!-- Title (edit mode) -->
                        <TextBox Style="{StaticResource LumosTextBox}"
                                 Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18"
                                 Margin="0,2,0,0"
                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <!-- Body -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="36,0,36,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ===== VIEW MODE ===== -->
                            <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolToVisibility}}">

                                <!-- Username row -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="USERNAME" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="#FF050810"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="14,10"
                                                MinHeight="42">
                                            <TextBlock Text="{Binding CurrentLogin.Username}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource GhostButton}"
                                                Content="COPY"
                                                Margin="8,0,0,0"
                                                MinHeight="42"
                                                Command="{Binding CopyUsernameCommand}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Password row -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="PASSWORD" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="#FF050810"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="14,10"
                                                MinHeight="42">
                                            <TextBlock Text="{Binding DisplayPassword}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource GhostButton}"
                                                Content="{Binding RevealLabel}"
                                                Margin="8,0,0,0"
                                                MinHeight="42"
                                                Command="{Binding RevealCommand}"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource GhostButton}"
                                                Content="COPY"
                                                Margin="8,0,0,0"
                                                MinHeight="42"
                                                Command="{Binding CopyPasswordCommand}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- TOTP card (only when entry has a TOTP secret) -->
                                <StackPanel Margin="0,0,0,16"
                                            Visibility="{Binding HasTotp, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="TOTP CODE" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                    <Border Background="#FF050810"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="14,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Code in big mono — gold to match its countdown ring -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TotpCodeDisplay}"
                                                       Foreground="{StaticResource AccentGoldBrush}"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="32"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>

                                            <!-- Countdown ring -->
                                            <views:TotpRing Grid.Column="1"
                                                            Fraction="{Binding TotpFractionRemaining}"
                                                            SecondsRemaining="{Binding TotpSecondsRemaining}"
                                                            IsExpiringSoon="{Binding TotpIsExpiringSoon}"
                                                            Margin="12,0,8,0"/>

                                            <!-- Copy button -->
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource GhostButton}"
                                                    Content="COPY"
                                                    MinHeight="42"
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding CopyTotpCommand}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- URL row -->
                                <StackPanel Margin="0,0,0,16"
                                            Visibility="{Binding CurrentLogin.Url, Converter={StaticResource StringToVisibility}}">
                                    <TextBlock Text="URL" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                    <Border Background="#FF050810"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="14,10"
                                            MinHeight="42">
                                        <TextBlock Text="{Binding CurrentLogin.Url}"
                                                   Foreground="{StaticResource AccentCyanBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>

                                <!-- Notes row -->
                                <StackPanel Margin="0,0,0,16"
                                            Visibility="{Binding Entry.Notes, Converter={StaticResource StringToVisibility}}">
                                    <TextBlock Text="NOTES" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                    <Border Background="#FF050810"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="14,10">
                                        <TextBlock Text="{Binding Entry.Notes}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>

                                <!-- ===== ATTACHMENTS ===== -->
                                <StackPanel Margin="0,0,0,16" DataContext="{Binding Attachments}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ATTACHMENTS"
                                                   Style="{StaticResource MonoLabel}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="+ ADD FILE"
                                                Style="{StaticResource GhostButton}"
                                                Command="{Binding AddCommand}"/>
                                    </Grid>

                                    <!-- Empty state -->
                                    <TextBlock Text="No files attached. Max 25 MB per file."
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,0,4"
                                               Visibility="{Binding HasAttachments, Converter={StaticResource InvertBoolToVisibility}}"/>

                                    <!-- File list -->
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FF050810"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Padding="10,8"
                                                        Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Glyph}"
                                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource AccentBlueBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FileName}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="13"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SizeDisplay}"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                                       FontSize="10"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Content="SELECT"
                                                                Style="{StaticResource GhostButton}"
                                                                Command="{Binding DataContext.SelectRowCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Selection actions + preview -->
                                    <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}"
                                                Margin="0,6,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Selected.FileName}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0"/>
                                            <Button Content="SAVE AS…"
                                                    Style="{StaticResource GhostButton}"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding SaveSelectedCommand}"/>
                                            <Button Content="REMOVE"
                                                    Style="{StaticResource DangerGhostButton}"
                                                    Command="{Binding DeleteSelectedCommand}"/>
                                        </StackPanel>

                                        <!-- Inline image preview -->
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                Background="#FF050810"
                                                Padding="8"
                                                MaxHeight="240"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding PreviewIsImage, Converter={StaticResource BoolToVisibility}}">
                                            <Image Source="{Binding PreviewBytes, Converter={StaticResource BytesToImage}}"
                                                   MaxHeight="220"
                                                   Stretch="Uniform"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- status / error -->
                                    <TextBlock Foreground="{StaticResource AccentBlueBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="11"
                                               Margin="0,6,0,0"
                                               Text="{Binding StatusMessage}"
                                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"/>
                                    <TextBlock Foreground="{StaticResource DangerBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"
                                               Text="{Binding ErrorMessage}"
                                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- ===== EDIT MODE ===== -->
                            <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">

                                <TextBlock Text="USERNAME" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource LumosTextBox}"
                                         Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="PASSWORD" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource LumosTextBox}"
                                         Text="{Binding EditPassword, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFontFamily}"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="TOTP SECRET (BASE32 OR OTPAUTH:// URI — LEAVE BLANK FOR NONE)"
                                           Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource LumosTextBox}"
                                         Text="{Binding EditTotpSecret, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFontFamily}"
                                         Margin="0,0,0,6"/>
                                <TextBlock Style="{StaticResource DangerText}"
                                           Margin="0,0,0,12"
                                           Text="{Binding EditTotpError}"
                                           Visibility="{Binding EditTotpError, Converter={StaticResource StringToVisibility}}"/>

                                <TextBlock Text="URL" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource LumosTextBox}"
                                         Text="{Binding EditUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="NOTES" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource LumosTextBox}"
                                         Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="100"
                                         Margin="0,0,0,12"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer with actions -->
                    <Grid Grid.Row="2" Margin="36,16,36,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status message (left) -->
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="11"
                                   Opacity="0.85"/>

                        <!-- View mode actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolToVisibility}}">
                            <Button Style="{StaticResource DangerGhostButton}"
                                    Content="{Binding DeleteButtonLabel}"
                                    Command="{Binding DeleteCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Style="{StaticResource GhostButton}"
                                    Content="EDIT"
                                    Command="{Binding EditCommand}"/>
                        </StackPanel>

                        <!-- Edit mode actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                            <Button Style="{StaticResource GhostButton}"
                                    Content="CANCEL"
                                    Command="{Binding CancelEditCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Style="{StaticResource PrimaryButton}"
                                    Content="SAVE"
                                    Padding="16,8"
                                    MinHeight="36"
                                    Command="{Binding SaveCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ============ ADD-ENTRY OVERLAY ============ -->
        <Grid Visibility="{Binding IsAddOverlayOpen, Converter={StaticResource BoolToVisibility}}">
            <!-- Backdrop dim -->
            <Rectangle Fill="#FF000000" Opacity="0.55"/>

            <!-- Centered add card -->
            <ContentControl Style="{StaticResource NeonCard}"
                            DataContext="{Binding AddEntry}"
                            Width="520"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                <StackPanel Margin="32,28">
                    <TextBlock Text="// NEW" Style="{StaticResource MonoLabel}" Margin="0,0,0,4"/>
                    <TextBlock Text="Add a login" Style="{StaticResource SectionHeading}" Margin="0,0,0,20"/>

                    <TextBlock Text="TITLE" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBox x:Name="AddTitleField"
                             Style="{StaticResource LumosTextBox}"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="USERNAME" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource LumosTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="PASSWORD" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource LumosTextBox}"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFontFamily}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="TOTP SECRET (OPTIONAL)" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource LumosTextBox}"
                             Text="{Binding TotpSecret, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFontFamily}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="URL" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource LumosTextBox}"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="NOTES" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource LumosTextBox}"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource DangerText}"
                               Margin="0,0,0,8"
                               Text="{Binding ErrorMessage}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostButton}"
                                Content="CANCEL"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0"/>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="ADD ENTRY"
                                Padding="20,10"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
