<UserControl x:Class="Lumos.Desktop.Views.NeonCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- v2: flat card. No glow halo, no glowing tron line. A 1px grey border,
         a thin steel-blue top accent, and subtle grey corner brackets. Matches
         the NeonCard style in Controls.xaml. -->
    <Border Background="{StaticResource CardGradientBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thin flat top accent (steel-blue hairline, no glow) -->
            <Rectangle Grid.Row="0" Height="2" Fill="{StaticResource ScanlineBrush}"/>

            <!-- Card content slot -->
            <Grid Grid.Row="1">
                <!-- Subtle grey corner brackets -->
                <Path Stroke="{StaticResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M 0,8 L 0,0 L 8,0"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="8,8,0,0"/>
                <Path Stroke="{StaticResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M 0,0 L 8,0 L 8,8"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,8,8,0"/>
                <Path Stroke="{StaticResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M 0,0 L 0,8 L 8,8"
                      HorizontalAlignment="Left" VerticalAlignment="Bottom"
                      Margin="8,0,0,8"/>
                <Path Stroke="{StaticResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M 0,8 L 8,8 L 8,0"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                      Margin="0,0,8,8"/>

                <!-- Actual content -->
                <ContentPresenter Content="{Binding CardContent, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
