<UserControl x:Class="Lumos.Desktop.Views.CreateVaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Lumos.Desktop.Views"
             xmlns:conv="clr-namespace:Lumos.Desktop.Converters">
    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:StrengthScoreToBrushConverter x:Key="ScoreToBrush"/>
    </UserControl.Resources>

    <Grid>
        <views:CyberBackdrop/>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="520">

            <Grid HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock Text="LUMOS"
                           Style="{StaticResource DisplayHeading}"
                           FontSize="{StaticResource FontSize3xl}"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource AccentGoldShadowColor}"
                                          BlurRadius="16"
                                          ShadowDepth="0"
                                          Opacity="0.45"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <TextBlock Text="// light a candle in the dark"
                       Style="{StaticResource MonoLabel}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <ContentControl Style="{StaticResource NeonCard}">
                <StackPanel Margin="32,28">
                    <TextBlock Text="// INIT"
                               Style="{StaticResource MonoLabel}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Create your vault"
                               Style="{StaticResource SectionHeading}"
                               Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource SecondaryText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"
                               Text="Choose a master password. This is the only key to your vault — Lumos uses zero-knowledge encryption, which means even Lumos can't recover it for you."/>
                    <TextBlock Style="{StaticResource SecondaryText}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WarningBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"
                               Text="If you forget it, your vault is gone."/>

                    <!-- Master password -->
                    <TextBlock Text="MASTER PASSWORD" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordField"
                                 Style="{StaticResource LumosPasswordBox}"
                                 PasswordChanged="PasswordField_PasswordChanged"
                                 Margin="0,0,0,12"/>

                    <!-- Strength meter -->
                    <Grid Margin="0,0,0,4">
                        <Border Background="{StaticResource BorderBrush}" Height="3"/>
                        <Border x:Name="StrengthBar"
                                Background="{Binding StrengthScore, Converter={StaticResource ScoreToBrush}}"
                                Height="3"
                                HorizontalAlignment="Left"
                                Width="0">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" CenterX="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                    <TextBlock Style="{StaticResource SecondaryText}"
                               Margin="0,4,0,12"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="11"
                               Text="{Binding StrengthLabel}"
                               Foreground="{Binding StrengthScore, Converter={StaticResource ScoreToBrush}}"/>

                    <!-- Confirm password -->
                    <TextBlock Text="CONFIRM" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ConfirmField"
                                 Style="{StaticResource LumosPasswordBox}"
                                 Margin="0,0,0,8"
                                 KeyDown="ConfirmField_KeyDown"/>

                    <TextBlock Style="{StaticResource SecondaryText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               Text="{Binding HintMessage}"
                               Visibility="{Binding HintMessage, Converter={StaticResource StringToVisibility}}"/>

                    <Button Content="CREATE VAULT"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Click="CreateButton_Click"/>

                    <TextBlock Style="{StaticResource DangerText}"
                               Margin="0,16,0,0"
                               Text="{Binding ErrorMessage}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </ContentControl>
        </StackPanel>
    </Grid>
</UserControl>
