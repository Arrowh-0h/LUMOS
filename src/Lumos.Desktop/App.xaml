<Application x:Class="Lumos.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Lumos.Desktop.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Controls.xaml"/>
                <ResourceDictionary Source="Resources/Themes/FormControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- App-wide converters -->
            <conv:StringEqualityConverter x:Key="StringEqualityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
